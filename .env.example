# Telegram Bot Token from @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Comma separated Telegram user IDs who get admin access
ADMIN_IDS=123456789

# Database (SQLite by default, swap for postgresql+psycopg://user:pass@host/db to migrate)
DATABASE_URL=sqlite:///./data/movies.db

# Default UI language: uz | en | ru
DEFAULT_LANGUAGE=en

# Directory where DB backups are written
BACKUP_DIR=./data/backups


# Directory for log files
LOG_DIR=./data/logs
LOG_LEVEL=INFO

# Bot username without @, used to build referral links
BOT_USERNAME=YourMovieBot
